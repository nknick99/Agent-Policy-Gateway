# KiroGate Production Environment
# Copy to .env and update values before deploying

# ─── Security (CHANGE THESE!) ───
KIROGATE_AGENT_TOKEN=change-me-use-a-strong-random-token
KIROGATE_JWT_SECRET=change-me-use-a-256-bit-random-key

# ─── Operator Credentials ───
KIROGATE_OPERATOR_EMAIL=admin@yourcompany.com
KIROGATE_OPERATOR_PASSWORD=change-me-strong-password
KIROGATE_OPERATOR_WORKSPACE=yourcompany

# ─── AWS Configuration ───
# For local dev (Floci): set AWS_ENDPOINT_URL
# For production: remove AWS_ENDPOINT_URL, use real IAM credentials
AWS_ENDPOINT_URL=http://floci:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ─── LLM Provider ───
# Options: mock, ollama, openai, anthropic, microservice
LLM_PROVIDER=mock
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ───
DATABASE_URL=postgresql://kirogate:kirogate@postgres:5432/kirogate
